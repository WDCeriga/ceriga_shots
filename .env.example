## Database
# DATABASE_URL=postgresql://...
#
# The floating feedback widget saves to the user_feedback table (same DATABASE_URL).

## Replicate
# REPLICATE_API_TOKEN=

## Optional: Upstash Redis (for distributed rate limiting)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

## Cloudflare R2 (S3-compatible)
#
# Required to enable storing images in R2:
# - R2_ACCOUNT_ID: your Cloudflare account id
# - R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: R2 API token credentials
# - R2_BUCKET: bucket name
#
# Optional (recommended):
# - R2_PUBLIC_BASE_URL: custom domain or public bucket base URL, e.g. https://assets.example.com
#
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=

## Stripe billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
#
# Optional: Studio plan free trial (days). Default 14. Set to 0 to disable.
# NEXT_PUBLIC_STUDIO_TRIAL_DAYS=14
#
# Credits available while Studio is in Stripe trialing status (default 30).
# NEXT_PUBLIC_STUDIO_TRIAL_CREDITS=30

## Optional: Admin finance assumptions
# FINANCE_COST_PER_ACTIVE_SUBSCRIBER=3
# FINANCE_FIXED_MONTHLY_COST=0
# FINANCE_COST_PER_MODEL_CALL=0.039

## Email verification (Resend)
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# NEXT_PUBLIC_APP_URL=https://ceriga-shots.vercel.app
# EMAIL_FROM=Ceriga Shots <noreply@yourdomain.com>

