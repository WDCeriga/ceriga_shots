## Database
# DATABASE_URL=postgresql://...

## Google / Gemini
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

## Cloudflare R2 (S3-compatible)
#
# Required to enable storing images in R2:
# - R2_ACCOUNT_ID: your Cloudflare account id
# - R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: R2 API token credentials
# - R2_BUCKET: bucket name
#
# Optional (recommended):
# - R2_PUBLIC_BASE_URL: custom domain or public bucket base URL, e.g. https://assets.example.com
#
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=

